# Runtime
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173,http://localhost:5174
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://localhost:27017/cloudmart

# Redis
REDIS_URL=redis://localhost:6379

# Auth/JWT/Cognito
JWT_SECRET=your_super_secret_jwt_key_here
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxx
COGNITO_HOSTED_UI_URL=https://cloudmart.auth.us-east-1.amazoncognito.com
COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxx/.well-known/jwks.json

# AWS Core
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=cloudmart-products
AWS_SES_FROM_EMAIL=noreply@cloudmart.com
ORDER_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/order-events
EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/email-jobs
IMAGE_RESIZE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/image-resize

# Upload constraints
UPLOAD_MAX_SIZE=10485760

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx

# Email templates
SES_TEMPLATE_ORDER_CONFIRMATION=order_confirmation
SES_TEMPLATE_ORDER_SHIPPED=order_shipped
SES_TEMPLATE_VENDOR_APPROVED=vendor_approved
SES_TEMPLATE_PASSWORD_RESET=password_reset
SES_TEMPLATE_SUBSCRIPTION_RECEIPT=subscription_receipt
SES_TEMPLATE_PAYOUT_NOTIFICATION=payout_notification
SES_TEMPLATE_WEEKLY_VENDOR_REPORT=weekly_vendor_report

# Seed defaults
SEED_ADMIN_EMAIL=admin@cloudmart.local
