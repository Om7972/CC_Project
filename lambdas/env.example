# Copy to .env in this folder before `npx serverless deploy`
# Backend should use the created SQS queue URL for AWS_SQS_QUEUE_URL.

MONGO_URI=mongodb+srv://user:pass@cluster/db
AWS_S3_BUCKET=your-bucket-name
AWS_SES_FROM_EMAIL=noreply@yourverifieddomain.com
CDN_BASE_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# Optional: ElastiCache / Redis (TLS rediss:// often required)
REDIS_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CACHE_TTL_SECONDS=1800
CORS_ORIGIN=https://your-frontend-origin.com

# Weekly vendor email: 0 = Sunday UTC (default)
WEEKLY_REPORT_WEEKDAY=0
